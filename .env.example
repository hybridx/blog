# Copy to `.env` and adjust (never commit `.env`):
#   cp .env.example .env
#
# Start local infra (PostgreSQL + MinIO), then apply schema:
#   podman compose up -d
#   # or: docker compose up -d
#   npx drizzle-kit push
#   npm run dev
#
# Values below match `compose.yaml` defaults so local dev mirrors prod wiring
# (same env names you will set in Kubernetes secrets).

# ---------------------------------------------------------------------------
# PostgreSQL — same role as the `postgres` Service in-cluster
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://blog:blog@localhost:5432/blog

# ---------------------------------------------------------------------------
# MinIO — same role as S3-compatible API (in prod: MINIO_* or external S3)
# ---------------------------------------------------------------------------
# Host:port for the MinIO API (from the host machine running `npm run dev`)
MINIO_ENDPOINT=localhost:9000
# Set true only when terminating TLS in front of MinIO (typical local: false)
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=blog-images

# ---------------------------------------------------------------------------
# App secrets (generate for local; use strong values in prod)
# ---------------------------------------------------------------------------
# Used for signing cookies / session material (set in k8s `blog-secrets`)
SESSION_SECRET=replace-with-openssl-rand-hex-32-or-similar

# ---------------------------------------------------------------------------
# OAuth — GitHub / Google apps (redirect URIs must include your dev origin)
# Example GitHub callback: http://localhost:4321/api/auth/github
# Example Google callback:  http://localhost:4321/api/auth/google
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Optional: GitHub content repo (fine-grained PAT), admin password hash, etc.
# ---------------------------------------------------------------------------
# GITHUB_PAT=
# ADMIN_USER=
# ADMIN_PASS_HASH=
